# Copia este archivo como .env para desarrollo local (no lo subas a git con valores reales)
# En Beanstalk, estas mismas claves van en Configuration > Software > Environment properties,
# apuntando al endpoint real de RDS y al secreto de Secrets Manager.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=manantial_ecommerce
DB_USER=root
DB_PASSWORD=

# URL real de Amplify una vez desplegado el frontend, ej:
# https://main.d1a2b3c4d5.amplifyapp.com
FRONTEND_ORIGIN=*
